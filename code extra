void setup() 
{
  Serial.begin(115200);

    xTaskCreatePinnedToCore(
                          Task1Code, //focntion de la tache
                          "Task 1", //nom de la tache
                          10000, //taille de la pile (words)
                          NULL, //paramètre d'entrée de la tâche
                          2, //priotriter de la tache (priorité plus haute)
                          &Task1, //Task handle
                          0 //Coeur sur lequel exécuter la tâche (Noyau 0)
                          );

    xTaskCreatePinnedToCore(
                          Task2Code,
                          "Task 2",
                          10000,
                          NULL,
                          2,
                          &Task2,
                          1
                          );

  pinMode(led_pin, OUTPUT);

  Serial.println("Choirsir dans quel fichier sauvegarder les données?");
  Serial.println(" 0 = fichier batterie || 1 = fichier data_1 || 2 = fichier data_2 || 3 = fichier data_3 || 4 = fichier data_4");
  Serial.println("!! après 30 secondes le fichier batterie sera selectionné !!");

  init_bluetooth();

  carte_sd();

  u8g2.begin();

}

//=======================================================coeur 1 configurer pour le scanner BLE===========================================//

void Task1Code(void *pvParameters)
{
  for (;;)
  {
        if (information_data == true && choix_fichier == true)
    {
      affichage_batterie();
    }
    delay(1);
 }
}
//=====================================================coeur 2 affichage batterie=================================================//
void Task2Code (void *pvParameters)
{
  for (;;) 
  {
    if (doConnect == true) 
    {
      if (connectToServer()) 
      {
        Serial.println("We are now connected to the BLE Server.");
      } 
      else 
      {
        Serial.println("We have failed to connect to the server; there is nothing more we will do.");
      }
      doConnect = false;
    }

  // If we are connected to a peer BLE Server, update the characteristic each time we are reached
  // with the current time since boot.
  if (connected) 
  {
    String newValue = "Time since boot: " + String(millis() / 1000);
    //Serial.println("Setting new characteristic value to \"" + newValue + "\"");

    // Set the characteristic's value to be the array of bytes that is actually a string.
    pRemoteCharacteristic->writeValue(newValue.c_str(), newValue.length());
  } 
  else if (doScan) 
  {
  BLEDevice::getScan()->start(0);  // this is just example to start scan after disconnect, most likely there is better way to do it in arduino
  }

  delay(100);
  }
}

